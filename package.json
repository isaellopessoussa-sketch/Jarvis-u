{
  "name": "jarvis-quantum-hud",
  "version": "4.5.0",
  "description": "Interface Cognitiva Stark HUD - Sistema de Comando Holográfico",
  "main": "index.html",
  "author": "Tony Stark",
  "private": true,
  "scripts": {
    "build": "mkdir -p www && cp index.html www/",
    "clean": "rm -rf www android/app/build"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  },
  "capacitor": {
    "appId": "com.starkindustries.jarvishud",
    "appName": "JARVIS OS",
    "webDir": "www",
    "plugins": {
      "ScreenOrientation": {
        "orientation": "landscape"
      }
    }
  }
}
